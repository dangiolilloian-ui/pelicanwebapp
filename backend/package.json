{
  "name": "pelican-backend",
  "version": "1.0.0",
  "description": "Pelican - Shift management API",
  "main": "src/index.js",
  "scripts": {
    "dev": "npx prisma migrate deploy && node --watch src/index.js",
    "start": "npx prisma migrate deploy && node src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node src/seeds/index.js",
    "db:reset": "npx prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "prisma": "^6.5.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  }
}
